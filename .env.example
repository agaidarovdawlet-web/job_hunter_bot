# Скопируй этот файл в .env и заполни своими значениями.
# Файл .env НЕ должен попадать в git (он уже в .gitignore).

# --- Telegram ---
# Получи токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# Узнать свой chat_id можно, написав боту @userinfobot
TELEGRAM_CHAT_ID=123456789

# --- HH API ---
HH_API_BASE_URL=https://api.hh.ru/vacancies
# 113 = Россия. Полный список кодов регионов: https://api.hh.ru/areas
HH_AREA=113
HH_PER_PAGE=20
HH_PAGES_PER_QUERY=1
HH_MAX_CONCURRENT_REQUESTS=4
HH_FAILURE_ALERT_RATIO=0.5
HH_USER_AGENT=job_hunter_bot/1.0 (contact: your_email@example.com)

# --- Gemini API ---
# Необязательно: если не задан, проект использует шаблонный черновик отклика.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SEMANTIC_SCORE_MIN=45
SEMANTIC_SCORE_MAX=70
SEMANTIC_SCORE_WEIGHT=0.4

# --- Поиск / фильтрация / оценка ---
# Необязательно: свой список запросов через запятую.
# Если не задано — используется список по умолчанию из config.py
# SEARCH_QUERIES=Junior Python Developer,Helpdesk,IT Support

MAX_EXPERIENCE_YEARS=3
SCORE_THRESHOLD=60

# --- База данных ---
# Локально можно оставить SQLite:
DATABASE_URL=sqlite+aiosqlite:///data/vacancies.db
# Для продакшена / GitHub Actions рекомендуется внешний Postgres:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-example.neon.tech/job_hunter
